<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - نظام الأدلة</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap">
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MMS.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="top-bar">
            <div class="container header-logos">
                <img src="~/images/theme/rghit-logo.png" alt="شعار الأكاديمية" class="logo-img">
                <h1 class="site-title">نظام الأدلة</h1>
                <img src="~/images/theme/left-logo.png" alt="شعار سلاح الجو" class="logo-img">
            </div>
        </div>
        <div class="container">
            <div class="nav-container">
                <button class="menu-toggle" id="mobile-menu-btn" onclick="toggleMenu()">☰ القائمة</button>
                <nav class="nav-links" id="main-nav">
                    <a href="@Url.Action("Index", "Home")" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                        لوحة التحكم
                    </a>
                    
                    @* Admin Menu *@
                    @if (ViewBag.UserRole == "admin")
                    {
                        <a href="@Url.Action("Index", "Users")" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Users" ? "active" : "")">
                            المستخدمون
                        </a>
                        <a href="@Url.Action("Index", "Standards")" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Standards" ? "active" : "")">
                            المعايير والمقاييس
                        </a>
                        <a href="@Url.Action("Index", "Files")" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Files" ? "active" : "")">
                            مراجعة الملفات
                        </a>
                        <a href="@Url.Action("Index", "Reports")" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Reports" ? "active" : "")">
                            التقارير والإحصائيات
                        </a>
                    }
                    
                    @* Standard Head Menu *@
                    @if (ViewBag.UserRole == "standard_head")
                    {
                        <a href="@Url.Action("MyStandards", "Standards")" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Standards" ? "active" : "")">
                            إدارة المقاييس
                        </a>
                        <a href="@Url.Action("Index", "Materials")" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Materials" ? "active" : "")">
                            صلاحيات المواد
                        </a>
                        <a href="@Url.Action("Index", "Files")" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Files" ? "active" : "")">
                            مراجعة الملفات
                        </a>
                    }
                    
                    @* Metric Head Menu *@
                    @if (ViewBag.UserRole == "metric_head")
                    {
                        <a href="@Url.Action("Index", "Materials")" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Materials" ? "active" : "")">
                            المجلدات والمواد
                        </a>
                    }
                </nav>
                
                <div class="user-nav">
                    <span class="text-secondary">أهلاً، @ViewBag.UserName</span>
                    <a href="@Url.Action("Logout", "Account")" class="btn-logout">تسجيل الخروج</a>
                </div>
            </div>
        </div>
    </header>
    
    <main class="main-content">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="site-footer">
        <div class="container">
            <p>&copy; 2026 - نظام الأدلة - نظام إدارة الدراسة الذاتية</p>
        </div>
    </footer>
    
    <script>
        function toggleMenu() {
            document.getElementById('main-nav').classList.toggle('show');
        }
    </script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
